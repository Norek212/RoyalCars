# ─── Discord Bot Config ───────────────────────────────────────────────────────
# Token bota (zakładka Bot na dev.discord.com)
TOKEN=twoj_token_bota

# ID aplikacji (zakładka General Information na dev.discord.com)
CLIENT_ID=id_twojej_aplikacji

# ID serwera (prawy klik na serwer > Kopiuj ID)
GUILD_ID=id_twojego_serwera
